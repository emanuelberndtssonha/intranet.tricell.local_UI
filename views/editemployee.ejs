<%- include('../masterframe/head.html') %>

	<% if (userId) { %>
		<%- include('../masterframe/newemployee_css.html') %>
			<%- include('../masterframe/newemployee_js.html') %>
				<%- include('../masterframe/loggedinmenu_css.html') %>
					<%- include('../masterframe/loggedinmenu_js.html') %>
						<div id="loggedinMenuLayer">
							<div id="userinfo">
								<b>User info:</b><br />
								Employee Code: <%= cookieemployeecode %> <br />
									Name: <%= cookiename %> <br />
										Login times: <%= cookielogintimes %> <br />
											Last login: <%= cookielastlogin %> <br />
							</div>

							<div id="chatbutton">
								<a href="javascript:void(0)" onClick="javascript:showChatLayer();"
									style="color:#ffffff;text-decoration:none;">Chat <span id="chatnumber">0</span></a>
							</div>

							<div id="chatLayer">
								<div id="chatLayerMessages"></div>
								<div id="chatLayerForm">
									<div style="width:230px;text-align:left;font-size:11px;color:#ffffff;">Write
										message:
										<form action="/" id="chatform">
											<input type="hidden" name="MAX_FILE_SIZE" value="50000000" />
											<textarea name="chatmessage" id="chatmessage" wrap="hard"
												style="width:230px;height:50px;border:0px;border-radius:5px;"></textarea>
											<input type="button" value="Chat"
												style="background-color:#cccccc;border:1px;font-size:10px;"
												onClick="submitChat()" />
										</form>
									</div>
								</div>
							</div>

							<div id="topsecret">
								<b>TOP SECRET</b><br />MATERIAL
							</div>

							<table border="0" cellspacing="0" cellpadding="0">
								<tr>
									<td height="1" width="150" bgcolor="#003366"></td>
								</tr>
							</table>

							<div class="loggedinbutton">
								<a href="javascript:void(0)" onClick="javascript:showCalcLayer();"
									style="color:#336699;text-decoration:none;">Tricell Calculator</a>
							</div>

							<table border="0" cellspacing="0" cellpadding="0">
								<tr>
									<td height="1" width="150" bgcolor="#003366"></td>
								</tr>
							</table>

							<div class="loggedinbutton">User Database</div>

							<table border="0" cellspacing="0" cellpadding="0">
								<tr>
									<td height="1" width="150" bgcolor="#003366"></td>
								</tr>
							</table>

							<div class="loggedinbutton">Research Database</div>

							<table border="0" cellspacing="0" cellpadding="0">
								<tr>
									<td height="1" width="150" bgcolor="#003366"></td>
								</tr>
							</table>

							<div class="loggedinbutton">
								<a href="/api/logout" style="color:#336699;text-decoration:none;">Log out</a>
							</div>

							<table border="0" cellspacing="0" cellpadding="0">
								<tr>
									<td height="1" width="150" bgcolor="#003366"></td>
								</tr>
							</table>
						</div>

						<div id="calcLayer">
							<h3>Tricell Calculator</h3>
							<form name="calc">
								<table id="calculator">
									<tr>
										<td class="calccell" colspan="4"><input class="calcdisplay" type="text"
												name="display" />
										</td>
									</tr>
									<tr>
										<td class="calccell"><input class="calcbutton" type="button" value="C"
												onClick="resetDisplay()" />
										</td>
										<td></td>
										<td></td>
										<td class="calccell"><input class="calcbutton" type="button" value="/"
												onClick="calc.display.value+='/'"></td>
									</tr>
									<tr>
										<td class="calccell"><input class="calcbutton" type="button" value="7"
												onClick="updateDisplay('7')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="8"
												onClick="updateDisplay('8')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="9"
												onClick="updateDisplay('9')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="*"
												onClick="updateDisplay('*')" /></td>
									</tr>
									<tr>
										<td class="calccell"><input class="calcbutton" type="button" value="4"
												onClick="updateDisplay('4')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="5"
												onClick="updateDisplay('5')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="6"
												onClick="updateDisplay('6')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="-"
												onClick="updateDisplay('-')" /></td>
									</tr>
									<tr>
										<td class="calccell"><input class="calcbutton" type="button" value="1"
												onClick="updateDisplay('1')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="2"
												onClick="updateDisplay('2')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="3"
												onClick="updateDisplay('3')" /></td>
										<td class="calccell"><input class="calcbutton" type="button" value="+"
												onClick="updateDisplay('+')" /></td>
									</tr>
									<tr>
										<td class="calccell"><input class="calcbutton" type="button" value="0"
												onClick="updateDisplay('0')" /></td>
										<td></td>
										<td></td>
										<td class="calccell"><input class="calcbutton" type="button" value="="
												onClick="calculate()" /></td>
									</tr>
								</table>
							</form>
						</div>
						<% } else { %>
							<div id="loginLayer">
								<p>Vänligen logga in för att se intranätet.</p>
							</div>
							<% } %>

								<%- include('../masterframe/header.html') %>
									<%- menu %>
										<%- include('../masterframe/infoStart.html')%>
											<h1>Edit Employee</h1>

											<form name="newemployeeform" action="/api/editemployee/<%= employeecode %>"
												onSubmit="return formCheckNewEmployee()" method="POST"
												enctype="multipart/form-data">
												<input type="hidden" name="fsignaturedate" value="" />

												<table id="infomiddle">
													<tr>
														<td width="166" valign="top">
															<table id="photocol">
																<tr>
																	<td id="employeecode">
																		EMPLOYEE CODE: <br />
																		<input type="text" name="femployeecode"
																			id="femployeecode" size="7" maxlength="7"
																			value="<%= employeecode %>">
																	</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>

																	<td id="photobox">
																		<img src="/<%= photo %>" alt="Employee"
																			width="164" /><br />
																		<label class="file-upload"><input type="file"
																				name="ffile" id="ffile"
																				accept="image/jpg" /></label>
																	</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td id="securitylevel">
																		SECURITY CLEARANCE LEVEL: <br />
																		<select class="select" name="fsecurityaccess"
																			id="fsecurityaccess">
																			<% const levels=['C', 'B' , 'A' ]; %>
																				<% levels.forEach(level=> { %>
																					<option value="<%= level %>"
																						<%=securityaccesslevel===level
																						? 'selected' : '' %>
																						><%= level %>
																					</option>
																					<% }); %>
																		</select>
																	</td>
																</tr>
															</table>
														</td>

														<td width="135" valign="top">
															<table>
																<tr>
																	<td class="variablecol">NAME: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">DATE OF BIRTH: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">SEX: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">BLOOD TYPE: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">HEIGHT: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">WEIGHT: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">DEPARTMENT: &nbsp;</td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="variablecol">RANK: &nbsp;</td>
																</tr>
															</table>
														</td>

														<td width="245" valign="top">
															<table>
																<tr>
																	<td class="valuecol"><input type="text" name="fname"
																			id="fname" size="20" maxlength="255"
																			value="<%= name %>" /></td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="date"
																			name="fdateofbirth" id="fdateofbirth"
																			size="20" maxlength="11"
																			value="<%= dateofbirth %>" />
																	</td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol">
																		<select class="select" name="fsex" id="fsex">
																			<% allGenders.forEach(sex=> { %>
																				<option value="<%= sex %>"
																					<%=currentSex===sex ? 'selected'
																					: '' %>
																					>
																					<%= sex %>
																				</option>
																				<% }); %>
																		</select>
																	</td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="text"
																			name="fbloodtype" id="fbloodtype" size="7"
																			maxlength="4" value="<%= bloodtype %>" />
																	</td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="text"
																			name="fheight" id="fheight" size="7"
																			maxlength="7" value="<%= height %>" /></td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="text"
																			name="fweight" id="fweight" size="7"
																			maxlength="7" value="<%= weight %>" /></td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="text"
																			name="fdepartment" id="fdepartment"
																			size="20" value="<%= department %>"
																			maxlength="255" />
																	</td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
																<tr>
																	<td class="tablespacer"></td>
																</tr>
																<tr>
																	<td class="valuecol"><input type="text" name="frank"
																			id="frank" size="20" value="<%= rank %>"
																			maxlength="255" /></td>
																</tr>
																<tr>
																	<td class="blackline"></td>
																</tr>
															</table>
														</td>
													</tr>
												</table>

												<br />
												<h1>Background:</h1>
												<textarea rows="5" cols="45" name="fbackground" id="fbackground"
													wrap="off"><%= background %></textarea>

												<h1>Strengths:</h1>
												<textarea rows="5" cols="45" name="fstrengths" id="fstrengths"
													wrap="off"><%= strengths %></textarea>

												<h1>Weaknesses:</h1>
												<textarea rows="5" cols="45" name="fweaknesses" id="fweaknesses"
													wrap="off"><%= weaknesses %></textarea>

												<p>
													<input type="submit" class="button" value="Update Employee" />
													<input class="button" type="reset" value="Reset Form" />
												</p>
											</form>
											<%- include('../masterframe/infoStop.html')%>
												<%- include('../masterframe/footer.html') %>
													<%- include('../masterframe/bottom.html') %>